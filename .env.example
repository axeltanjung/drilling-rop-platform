# ===== API =====
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# ===== Database =====
DATABASE_URL=sqlite:///./data/drilling.db

# ===== Paths =====
DATA_DIR=./data
RAW_DATA_PATH=./data/raw/drilling_telemetry.csv
